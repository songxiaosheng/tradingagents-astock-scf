{
  "name": "tradingagents-astock-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "npm run types && tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.client.json --noEmit && vite build",
    "deploy": "npm run check && wrangler deploy",
    "dev": "vite build --watch & wrangler dev",
    "types": "wrangler types --env-file .dev.vars.example"
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "lucide": "^0.468.0",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "wrangler": "^4.110.0"
  }
}
